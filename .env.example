# Volo Index — Server Configuration
# Copy to .env and fill in values.

# Server
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://localhost:5432/voloindex
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_SSL=false

# Anthropic (required in production)
ANTHROPIC_API_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_CHAT_WINDOW_MS=60000
RATE_LIMIT_CHAT_MAX=30

# CORS
CORS_ORIGINS=http://localhost:3000
