# Volo Index — Server Configuration
# Copy to .env and fill in values.

# Server
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://localhost:5432/voloindex
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_SSL=false

# Anthropic (required in production)
ANTHROPIC_API_KEY=

# Auth — T2-C (JWT_SECRET required in production; dev falls back to a fixed dev secret)
JWT_SECRET=
JWT_TTL_SECONDS=86400
MAGIC_LINK_TTL_MINUTES=30
# Absolute base URL used in magic-link emails. MUST be set in production
# (unset falls back to the request Host header — host-header injection risk).
AUTH_BASE_URL=
# Shared key for server-internal endpoints (X-Internal-Key). Unset = random per
# process start, which breaks internal calls across restarts/instances — set explicitly.
INTERNAL_API_KEY=
# 'postmark' | 'sendgrid' | '' (empty = log magic links to console, dev only)
EMAIL_PROVIDER=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_CHAT_WINDOW_MS=60000
RATE_LIMIT_CHAT_MAX=30

# CORS
CORS_ORIGINS=http://localhost:3000
